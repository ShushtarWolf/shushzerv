{
  "name": "shushzerv",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "TMPDIR=/tmp nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview --port 3000",
    "start": "node --env-file=.env .output/server/index.mjs",
    "postinstall": "nuxt prepare && prisma generate",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:reset": "prisma db push --force-reset && prisma db seed",
    "db:studio": "prisma studio",
    "tutorial:pdf": "bash scripts/generate-tutorial-pdf.sh tutorial",
    "shushbot:pdf": "bash scripts/generate-tutorial-pdf.sh shushbot",
    "guide:pdf": "bash scripts/generate-tutorial-pdf.sh guide",
    "guide:screenshots": "node scripts/capture-guide-screenshots.mjs && node scripts/capture-guide-extra.mjs",
    "guide:visual-pdf": "node scripts/build-visual-guide-html.mjs && bash scripts/generate-tutorial-pdf.sh visual",
    "guide:build": "node scripts/build-visual-guide-html.mjs",
    "guide:tour": "node scripts/build-site-tour.mjs",
    "guide:tour:export": "node scripts/build-site-tour.mjs && node scripts/export-site-tour.mjs",
    "guide:all": "npm run guide:screenshots && npm run guide:build && npm run guide:visual-pdf",
    "docs:pdf": "bash scripts/generate-tutorial-pdf.sh all",
    "smoke": "node scripts/smoke.mjs",
    "qa": "node scripts/qa-checklist.mjs",
    "qa:fast": "QA_STEP_MS=0 node scripts/qa-checklist.mjs",
    "qa:flows": "node scripts/qa-flows.mjs",
    "demo:images": "node scripts/fetch-demo-images.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "prisma": {
    "seed": "node --import tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fontsource-variable/vazirmatn": "^5.2.8",
    "@nuxtjs/i18n": "^10.4.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@prisma/client": "^6.19.3",
    "@vite-pwa/nuxt": "^1.1.1",
    "apexcharts": "^5.15.0",
    "leaflet": "^1.9.4",
    "nuxt": "^4.4.7",
    "nuxt-auth-utils": "^0.5.29",
    "prisma": "^6.19.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vue": "^3.5.35",
    "vue-router": "^5.1.0",
    "vue3-apexcharts": "^1.11.1"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "vitest": "^3.2.6"
  }
}
