generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  ATHLETE
  COACH
  CLUB_ADMIN
  PLATFORM_ADMIN
}

enum WalletTxType {
  TOP_UP
  BOOKING
  CLASS
  COACH_SESSION
  REFUND
  PAYOUT
  COACH_EARNING
  PLATFORM_FEE
}

enum SlotStatus {
  AVAILABLE
  BOOKED
  BLOCKED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum PaymentStatus {
  PAY_AT_CLUB
  PAID
}

enum BookingSource {
  PLATFORM
  CLUB
}

enum EquipmentMode {
  PROVIDED
  RENTAL
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  PRO
}

enum ClassStatus {
  OPEN
  FULL
  CANCELLED
}

enum MatchStatus {
  OPEN
  FULL
  COMPLETED
  CANCELLED
}

enum GenderPolicy {
  MEN
  WOMEN
  FAMILY
  MIXED
}

enum UserGender {
  MALE
  FEMALE
}

enum ClassType {
  GROUP
  SEMI_PRIVATE
}

enum PackageStatus {
  ACTIVE
  INACTIVE
}

enum PackageGroupMode {
  OPEN
  WITH_STUDENTS
}

enum PlanType {
  TRAINING
  DIET
}

enum TournamentStatus {
  OPEN
  FULL
  COMPLETED
  CANCELLED
}

enum NotificationType {
  BOOKING
  MATCH
  CLASS
  PLAN
  SYSTEM
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String
  name           String
  nameEn         String?
  role           Role      @default(ATHLETE)
  locale         String    @default("fa")
  phone          String?
  gender         UserGender?
  favoriteSports String?
  onboardedAt    DateTime?
  suspendedAt    DateTime?
  createdAt      DateTime  @default(now())

  ownedClubs        Club[]              @relation("ClubOwner")
  coachProfile      Coach?
  bookings          Booking[]
  athleteProfile    AthleteProfile?
  classEnrollments  ClassEnrollment[]
  packageEnrollments PackageEnrollment[]
  createdMatches    OpenMatch[]         @relation("MatchCreator")
  matchParticipants MatchParticipant[]
  planAssignments   PlanAssignment[]
  badges            UserBadge[]
  reviews           Review[]
  conversations     ConversationMember[]
  messages          Message[]
  wallet            Wallet?
  walletTransactions WalletTransaction[] @relation("UserWalletTx")
  notifications     Notification[]
  tournamentRegs    TournamentRegistration[]
  coachSessions     CoachSession[]      @relation("CoachSessionAthlete")
}

model Wallet {
  id        String   @id @default(cuid())
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ClubWallet {
  id        String   @id @default(cuid())
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt

  clubId String @unique
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)
}

model WalletTransaction {
  id          String       @id @default(cuid())
  type        WalletTxType
  amount      Int
  balanceAfter Int
  noteFa      String?
  noteEn      String?
  referenceId String?
  createdAt   DateTime     @default(now())

  userId String?
  user   User?  @relation("UserWalletTx", fields: [userId], references: [id], onDelete: SetNull)
  clubId String?
  club   Club?  @relation(fields: [clubId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([clubId, createdAt])
}

model Sport {
  id      String  @id @default(cuid())
  slug    String  @unique
  nameFa  String
  nameEn  String
  icon    String
  color   String
  group   String

  courts        Court[]
  coaches       Coach[]
  news          NewsArticle[]
  classSessions ClassSession[]
  classPackages ClassPackage[]
  openMatches   OpenMatch[]
  athleteLevels AthleteProfile[]
  trainingPlans TrainingPlan[]
  tournaments   Tournament[]
}

model Club {
  id        String   @id @default(cuid())
  slug      String   @unique
  nameFa    String
  nameEn    String
  addressFa String
  addressEn String
  city      String
  district  String?
  lat       Float?
  lng       Float?
  rating    Float    @default(0)
  priceFrom Int      @default(0)
  discount  Int?
  image     String?
  featured  Boolean  @default(false)
  slotDurationMinutes Int    @default(120)
  slotOpenTime        String @default("08:00")
  slotCloseTime       String @default("22:00")
  cancellationPolicyFa String?
  cancellationPolicyEn String?
  cancellationHours    Int     @default(24)
  createdAt DateTime @default(now())

  ownerId   String?
  owner     User?    @relation("ClubOwner", fields: [ownerId], references: [id])

  courts        Court[]
  classSessions ClassSession[]
  classPackages ClassPackage[]
  activities    ClubActivity[]
  openMatches   OpenMatch[]
  reviews       Review[]
  wallet        ClubWallet?
  transactions  WalletTransaction[]
  addons        CourtAddon[]
  tournaments   Tournament[]
  coachSessions CoachSession[]
}

model Court {
  id           String        @id @default(cuid())
  nameFa       String
  nameEn       String
  surface      String?
  indoor       Boolean       @default(true)
  genderPolicy GenderPolicy  @default(MIXED)

  clubId  String
  club    Club    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  sportId String
  sport   Sport   @relation(fields: [sportId], references: [id])

  slots  Slot[]
  addons CourtAddon[]
}

model Slot {
  id        String     @id @default(cuid())
  date      String
  startTime String
  endTime   String
  price     Int
  status    SlotStatus @default(AVAILABLE)
  ownerNote String?

  courtId String
  court   Court   @relation(fields: [courtId], references: [id], onDelete: Cascade)

  booking      Booking?
  coachSession CoachSession?

  @@index([courtId, date])
}

model Coach {
  id       String  @id @default(cuid())
  nameFa   String
  nameEn   String
  city     String
  rating   Float   @default(0)
  sessions     Int     @default(0)
  sessionPrice Int     @default(300000)
  photo        String?
  bioFa        String?
  bioEn        String?
  featured     Boolean @default(false)

  sportId  String
  sport    Sport   @relation(fields: [sportId], references: [id])
  userId   String? @unique
  user     User?   @relation(fields: [userId], references: [id])

  classSessions ClassSession[]
  classPackages ClassPackage[]
  trainingPlans TrainingPlan[]
  coachSessions CoachSession[]
  reviews       Review[]
  equipment     CoachEquipment[]
}

model Booking {
  id            String        @id @default(cuid())
  status        BookingStatus @default(CONFIRMED)
  paymentStatus PaymentStatus @default(PAY_AT_CLUB)
  source        BookingSource @default(PLATFORM)
  guestName     String?
  playerCount   Int           @default(2)
  ownerNote     String?
  createdAt     DateTime      @default(now())

  userId String?
  user   User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  slotId String @unique
  slot   Slot   @relation(fields: [slotId], references: [id], onDelete: Cascade)

  equipmentTotal Int                @default(0)
  equipment      BookingEquipment[]
}

model BookingEquipment {
  id       String        @id @default(cuid())
  quantity Int           @default(1)
  nameFa   String
  nameEn   String
  price    Int           @default(0)
  mode     EquipmentMode

  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  addonId   String?
  addon     CourtAddon? @relation(fields: [addonId], references: [id], onDelete: SetNull)
}

model NewsArticle {
  id        String  @id @default(cuid())
  slug      String  @unique
  titleFa   String
  titleEn   String
  excerptFa String
  excerptEn String
  bodyFa    String
  bodyEn    String
  coverUrl  String?
  date      String

  sportId String?
  sport   Sport?  @relation(fields: [sportId], references: [id])
}

model AthleteProfile {
  id            String     @id @default(cuid())
  level         SkillLevel @default(BEGINNER)
  matchesPlayed Int        @default(0)
  wins          Int        @default(0)
  xp            Int        @default(0)

  userId  String @unique
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  sportId String
  sport   Sport  @relation(fields: [sportId], references: [id])
}

model UserBadge {
  id       String   @id @default(cuid())
  code     String
  earnedAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, code])
}

model Review {
  id        String    @id @default(cuid())
  rating    Int       @default(5)
  bodyFa    String
  bodyEn    String
  replyFa   String?
  replyEn   String?
  repliedAt DateTime?
  createdAt DateTime  @default(now())

  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  clubId  String?
  club    Club?  @relation(fields: [clubId], references: [id], onDelete: Cascade)
  coachId String?
  coach   Coach? @relation(fields: [coachId], references: [id], onDelete: Cascade)
}

model Conversation {
  id        String   @id @default(cuid())
  titleFa   String?
  titleEn   String?
  isGroup   Boolean  @default(false)
  matchId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  members  ConversationMember[]
  messages Message[]
}

model ConversationMember {
  id       String   @id @default(cuid())
  joinedAt DateTime @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model Message {
  id        String   @id @default(cuid())
  body      String
  createdAt DateTime @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model ClassSession {
  id           String       @id @default(cuid())
  titleFa      String
  titleEn      String
  date         String
  startTime    String
  endTime      String
  price        Int
  maxSeats     Int          @default(12)
  bookedSeats  Int          @default(0)
  classType    ClassType    @default(GROUP)
  genderPolicy GenderPolicy @default(MIXED)
  minLevel     SkillLevel   @default(BEGINNER)
  maxLevel     SkillLevel   @default(PRO)
  status       ClassStatus  @default(OPEN)
  clubNote     String?
  coachNote    String?

  clubId  String
  club    Club    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  sportId String
  sport   Sport   @relation(fields: [sportId], references: [id])
  coachId String?
  coach   Coach?  @relation(fields: [coachId], references: [id])

  enrollments ClassEnrollment[]
}

model ClassEnrollment {
  id            String        @id @default(cuid())
  paymentStatus PaymentStatus @default(PAY_AT_CLUB)
  createdAt     DateTime      @default(now())

  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  classSessionId String
  classSession   ClassSession @relation(fields: [classSessionId], references: [id], onDelete: Cascade)

  @@unique([userId, classSessionId])
}

model ClassPackage {
  id              String            @id @default(cuid())
  titleFa         String
  titleEn         String
  descFa          String
  descEn          String
  price           Int
  sessionsPerWeek Int               @default(1)
  durationWeeks   Int               @default(4)
  classType       ClassType         @default(GROUP)
  groupMode       PackageGroupMode  @default(OPEN)
  genderPolicy    GenderPolicy      @default(MIXED)
  minLevel        SkillLevel        @default(BEGINNER)
  maxLevel        SkillLevel        @default(PRO)
  maxSeats        Int               @default(12)
  bookedSeats     Int               @default(0)
  daysOfWeek      String            @default("SAT")
  startTime       String
  endTime         String
  status          PackageStatus     @default(ACTIVE)
  featured        Boolean           @default(false)
  createdAt       DateTime          @default(now())

  clubId  String?
  club    Club?   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  coachId String?
  coach   Coach?  @relation(fields: [coachId], references: [id], onDelete: SetNull)
  sportId String
  sport   Sport   @relation(fields: [sportId], references: [id])

  enrollments PackageEnrollment[]
}

model PackageEnrollment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  packageId String
  package   ClassPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@unique([userId, packageId])
}

model OpenMatch {
  id          String      @id @default(cuid())
  city        String
  date        String
  startTime   String
  maxPlayers  Int         @default(4)
  joinedCount Int         @default(1)
  minLevel    SkillLevel  @default(BEGINNER)
  maxLevel    SkillLevel  @default(PRO)
  status      MatchStatus @default(OPEN)
  notesFa     String?
  notesEn     String?
  shareToken  String?     @unique
  createdAt   DateTime    @default(now())

  sportId   String
  sport     Sport  @relation(fields: [sportId], references: [id])
  clubId    String?
  club      Club?  @relation(fields: [clubId], references: [id])
  creatorId String
  creator   User   @relation("MatchCreator", fields: [creatorId], references: [id], onDelete: Cascade)

  participants MatchParticipant[]
}

model MatchParticipant {
  id        String   @id @default(cuid())
  joinedAt  DateTime @default(now())

  matchId String
  match   OpenMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId  String
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
}

model TrainingPlan {
  id       String   @id @default(cuid())
  titleFa  String
  titleEn  String
  bodyFa   String
  bodyEn   String
  planType PlanType @default(TRAINING)

  coachId String
  coach   Coach  @relation(fields: [coachId], references: [id], onDelete: Cascade)
  sportId String?
  sport   Sport? @relation(fields: [sportId], references: [id])

  assignments PlanAssignment[]
}

model PlanAssignment {
  id          String    @id @default(cuid())
  assignedAt  DateTime  @default(now())
  completedAt DateTime?
  notes       String?

  planId    String
  plan      TrainingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  athleteId String
  athlete   User         @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@unique([planId, athleteId])
}

model ClubActivity {
  id      String @id @default(cuid())
  titleFa String
  titleEn String
  descFa  String
  descEn  String
  date    String
  startTime String

  clubId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)
}

model CourtAddon {
  id            String         @id @default(cuid())
  nameFa        String
  nameEn        String
  price         Int            @default(0)
  mode          EquipmentMode  @default(RENTAL)
  maxPerBooking Int            @default(4)
  stock         Int?

  clubId  String
  club    Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  courtId String?
  court   Court? @relation(fields: [courtId], references: [id], onDelete: SetNull)

  bookingItems BookingEquipment[]
}

model CoachEquipment {
  id            String        @id @default(cuid())
  nameFa        String
  nameEn        String
  price         Int           @default(0)
  mode          EquipmentMode @default(PROVIDED)
  maxPerBooking Int           @default(4)
  stock         Int?

  coachId String
  coach   Coach  @relation(fields: [coachId], references: [id], onDelete: Cascade)

  sessionItems CoachSessionEquipment[]
}

model Tournament {
  id              String           @id @default(cuid())
  titleFa         String
  titleEn         String
  descFa          String
  descEn          String
  date            String
  startTime       String
  maxParticipants Int              @default(32)
  joinedCount     Int              @default(0)
  price           Int              @default(0)
  status          TournamentStatus @default(OPEN)

  sportId String
  sport   Sport  @relation(fields: [sportId], references: [id])
  clubId  String?
  club    Club?  @relation(fields: [clubId], references: [id])

  registrations TournamentRegistration[]
}

model TournamentRegistration {
  id           String   @id @default(cuid())
  registeredAt DateTime @default(now())

  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  titleFa   String
  titleEn   String
  bodyFa    String?
  bodyEn    String?
  link      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model CoachSession {
  id            String        @id @default(cuid())
  date          String
  startTime     String
  endTime       String
  price         Int
  status        BookingStatus @default(PENDING)
  paymentStatus PaymentStatus @default(PAY_AT_CLUB)
  coachNote     String?
  createdAt     DateTime      @default(now())

  coachId   String
  coach     Coach  @relation(fields: [coachId], references: [id], onDelete: Cascade)
  athleteId String
  athlete   User   @relation("CoachSessionAthlete", fields: [athleteId], references: [id], onDelete: Cascade)
  clubId    String?
  club      Club?  @relation(fields: [clubId], references: [id])
  slotId    String? @unique
  slot      Slot?  @relation(fields: [slotId], references: [id])

  equipmentTotal Int                     @default(0)
  equipment      CoachSessionEquipment[]
}

model CoachSessionEquipment {
  id       String        @id @default(cuid())
  quantity Int           @default(1)
  nameFa   String
  nameEn   String
  price    Int           @default(0)
  mode     EquipmentMode

  sessionId   String
  session     CoachSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  equipmentId String?
  equipment   CoachEquipment? @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
}
